diff --git a/.env.example b/.env.example
new file mode 100644
index 0000000..b707e16
--- /dev/null
+++ b/.env.example
@@ -0,0 +1,48 @@
+# -----------------------------
+# Core runtime
+# -----------------------------
+APP_ENV=dev
+LOG_LEVEL=INFO
+LOG_PATH=logs/app.log
+
+# -----------------------------
+# Security / API keys
+# Never hardcode keys in code
+# -----------------------------
+OPENAI_API_KEY=
+TMDB_API_KEY=
+
+# -----------------------------
+# LLM and Agent mode
+# -----------------------------
+USE_REAL_LLM=false
+LLM_PROVIDER=openai
+LLM_MODEL=gpt-4o-mini
+
+# -----------------------------
+# Data source switches
+# If false, use local fixture files only
+# -----------------------------
+ENABLE_TMDB_API=false
+FIXTURE_MOVIES_CSV=data/fixtures/sample_movies.csv
+FIXTURE_TMDB_JSON=data/fixtures/tmdb_sample_movies.json
+
+# -----------------------------
+# Storage paths
+# -----------------------------
+SQLITE_PATH=storage/movie_agent.db
+VECTOR_DB_BACKEND=chroma
+VECTOR_DB_PATH=storage/chroma_db
+
+# -----------------------------
+# Embedding / retrieval
+# -----------------------------
+EMBEDDING_MODEL=all-MiniLM-L6-v2
+DEFAULT_TOP_K=5
+
+# -----------------------------
+# Business thresholds
+# -----------------------------
+MIN_VOTE_COUNT=100000
+HIGH_RATING_THRESHOLD=7.5
+YEAR_FILTER_DEFAULT=2015
