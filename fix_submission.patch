new file mode 100644
index 0000000..16062e5
--- /dev/null
+++ b/.gitignore
@@ -0,0 +1,43 @@
+# Environment variables
+.env
+.env.*
+!.env.example
+
+# Python caches
+__pycache__/
+*.py[cod]
+*.so
+.pytest_cache/
+.mypy_cache/
+.coverage
+
+# Virtual environments
+.venv/
+venv/
+env/
+
+# Logs
+logs/*.log
+logs/*.txt
+
+# Local storage / databases
+storage/*.db
+storage/*.sqlite
+storage/*.sqlite3
+
+# Vector DB persistence (Chroma / FAISS)
+storage/chroma_db/
+storage/vector_store/
+storage/faiss_index/
+*.faiss
+*.index
+
+# Processed outputs
+output/
+data/processed/*
+!data/processed/.gitkeep
+
+# OS / editor
+.DS_Store
+.vscode/
+.idea/
